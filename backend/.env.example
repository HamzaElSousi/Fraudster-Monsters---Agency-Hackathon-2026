# Copy this file to backend/.env and fill in real values.
# backend/.env is gitignored — never commit credentials.

# ── Database ──────────────────────────────────────────────────────────────────
# Shared PostgreSQL (Render.com) — for dual-DB verification badge
DB_CONNECTION_STRING=postgresql://user:PASSWORD@host:5432/database

# ── DuckDB data path (local dev only) ────────────────────────────────────────
# Leave unset to auto-resolve to <repo_root>/data
# DATA_DIR=/path/to/your/data

# ── AI Provider (pick one on event day) ──────────────────────────────────────
# Option A: AWS Bedrock (provided by Amazon on event day)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-opus-4-6-20251101-v1:0

# Option B: Anthropic direct API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Option C: Gemini direct API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
