# Copy this file to backend/.env and fill in real values.
# backend/.env is gitignored — never commit credentials.

# ── Database ──────────────────────────────────────────────────────────────────
# Shared PostgreSQL (Render.com) — for dual-DB verification badge
DB_CONNECTION_STRING=postgresql://user:PASSWORD@host:5432/database

# ── DuckDB data path ─────────────────────────────────────────────────────────
# Leave unset to auto-resolve to <repo_root>/data
# DATA_DIR=/path/to/your/data

# ── S3 Data Bucket (auto-syncs missing files on startup) ────────────────────
# Set this to your S3 bucket name. On startup, if local JSONL files are missing,
# the backend will download them from S3 using the AWS credentials below.
S3_DATA_BUCKET=agency2026-team-20

# ── AI Provider — AWS Bedrock ────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-west-2
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
