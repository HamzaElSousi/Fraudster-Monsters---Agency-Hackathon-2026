# Database connection - use the hackathon shared DB or local
DB_CONNECTION_STRING=postgresql://hackathon_readonly:PASSWORD@host:5432/database

# Set to "true" to use mock data (no DB needed), "false" for live DB
MOCK_MODE=true

# ── AI Provider (pick one on event day) ──────────────────────────────────────
# Option A: AWS Bedrock (provided by Amazon on event day)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-opus-4-6-20251101-v1:0

# Option B: Anthropic direct API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Server
HOST=0.0.0.0
PORT=8000
